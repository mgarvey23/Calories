rules_version = '2';

// Paste these rules into Firestore -> Rules in the Firebase console.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and write only their own diary document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared community food database: any signed-in user can read and
    // contribute foods; nobody can delete.
    match /foods/{foodId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
